{
  "name": "stronk-pi-plugin",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "description": "Guarded Pi Coding Agent extension for Stronk Pi.",
  "main": "src/index.mjs",
  "files": [
    "README.md",
    "package.json",
    "src/",
    "scripts/security-check.mjs",
    "scripts/installed-artifact-smoke.mjs"
  ],
  "scripts": {
    "test": "node --test",
    "lint:security": "node scripts/security-check.mjs",
    "smoke:installed": "node scripts/installed-artifact-smoke.mjs",
    "check": "npm run test && npm run lint:security",
    "version:bump": "node scripts/bump-version.mjs"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
